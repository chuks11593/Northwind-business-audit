    "# Create the Restock Alert flag\n",
    "# Risk: UnitsInStock is less than or equal to the ReorderLevel\n",
    "df_products['Restock_Alert'] = df_products.apply(\n",
    "    lambda x: 'CRITICAL' if x['UnitsInStock'] <= x['ReorderLevel'] else 'HEALTHY', \n",
    "    axis=1\n",
    ")\n",
    "\n",
    "# Filter for at-risk products\n",
    "stockout_risk = df_products[df_products['Restock_Alert'] == 'CRITICAL']\n",
    "\n",
    "# Sort by lowest stock first to prioritize the audit\n",
    "stockout_risk = stockout_risk.sort_values(by='UnitsInStock')\n",
    "\n",
    "print(f\"Found {len(stockout_risk)} products at risk of stockout:\")\n",
    "print(stockout_risk[['ProductName', 'UnitsInStock', 'ReorderLevel']])"
   ]

    "import pandas as pd\n",
    "\n",
    "# 1. Load your original datasets\n",
    "df_order_details = pd.read_csv('Downloads/order_details.csv')\n",
    "df_orders = pd.read_csv('Downloads/orders.csv')\n",
    "df_products = pd.read_csv('Downloads/products.csv')\n",
    "\n",
    "# 2. Make df_details your starting point\n",
    "df_details = df_order_details.copy()\n",
    "\n",
    "# 3. Bring in order info (matching on 'order_id')\n",
    "df_details = df_details.merge(df_orders, on='OrderID', how='left')\n",
    "\n",
    "# 4. Bring in product info (matching on 'product_id')\n",
    "df_details = df_details.merge(df_products, on='ProductID', how='left')\n",
    "\n",
    "# 5. Display the final master dataframe\n",
    "df_details.head()"
   ]
